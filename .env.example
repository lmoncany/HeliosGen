# ── Quick start (guest mode) ──────────────────────────────────────────────────
# Set GUEST_MODE=true to run without Supabase or R2 — see .env.guest for details.
# Data is saved to data/guest-db.json; media is saved to public/generated/.
GUEST_MODE=
# KIE_API_KEY is only read in guest mode (production uses per-user keys via Settings UI).
KIE_API_KEY=

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set NEXT_PUBLIC_DEMO_MODE=true to replace the sign-in/signup modal with a
# prompt pointing visitors to the GitHub repo to self-host.
NEXT_PUBLIC_DEMO_MODE=

# ── Kie.ai ────────────────────────────────────────────────────────────────────
# No shared API key needed — each user saves their own key via the Settings UI.

# Public URL where kie.ai POSTs job completion results (webhook).
# Must be reachable from the internet.
# Local dev: use ngrok → ngrok http 3000
# Production: your deployed domain, e.g. https://your-app.vercel.app
CALLBACK_BASE_URL=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Settings → API in your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Account ID: Cloudflare dashboard sidebar
R2_ACCOUNT_ID=
# API token: R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public CDN URL — enable public access on the bucket first
R2_PUBLIC_URL=

# ── Azure OpenAI (optional) ───────────────────────────────────────────────────
# Only needed if routing models through Azure AI Foundry instead of Kie.ai
AZURE_API_KEY=
