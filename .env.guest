# ── Guest Mode ────────────────────────────────────────────────────────────────
# Copy this file to .env.local to run without Supabase or R2.
# Only kie.ai API key + ngrok are required.

GUEST_MODE=true
NEXT_PUBLIC_GUEST_MODE=true

# Your kie.ai API key (from https://kie.ai → account settings)
KIE_API_KEY=your_kie_api_key_here

# ngrok public URL — run: ngrok http 3000
# Then paste the https://xxxx.ngrok-free.app URL here
CALLBACK_BASE_URL=https://xxxx.ngrok-free.app

# ── Dummy Supabase values (required so the client initializes without crashing)
# These point nowhere — no real Supabase connection is made in guest mode.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=dummy-anon-key
SUPABASE_SERVICE_ROLE_KEY=dummy-service-key

# ── Data is persisted to disk ─────────────────────────────────────────────────
# Generated files  → public/generated/   (served as static assets)
# Generation history → data/guest-db.json
